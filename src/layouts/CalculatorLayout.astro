---
import BaseLayout from "./BaseLayout.astro";
import CalculatorForm from "../components/CalculatorForm.astro";
import FAQ from "../components/FAQ.astro";
import CalculatorCard from "../components/CalculatorCard.astro";
import ArticleCard from "../components/ArticleCard.astro";
import ToolIcon from "../components/ToolIcon.astro";
import { calculators, calculatorMap, categoryLabels } from "../data/calculators";
import { getCalculatorSchema, getFaqSchema } from "../utils/schema";
import { getCollection } from "astro:content";
import type { CalculatorConfig } from "../types/calculator";
import { resolveSiteUrl } from "../utils/site";

type Props = {
  calculator: CalculatorConfig;
};

const { calculator } = Astro.props;
const canonical = resolveSiteUrl(`/${calculator.slug}`, Astro.site);
const relatedCalculators = calculator.related
  .map((slug) => calculatorMap.get(slug))
  .filter((item): item is CalculatorConfig => Boolean(item));
const relatedArticles = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((post) => post.data.relatedCalculators.includes(calculator.slug))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 6);
const supportingLabel =
  calculator.category === "pregnancy"
    ? "Timing and pregnancy planning"
    : calculator.category === "nutrition"
      ? "Food, intake, and meal planning"
      : calculator.category === "health"
        ? "Sleep, heart, and daily health checks"
        : "Body measurements, calories, and training goals";

const sectionTitles = calculator.sections.map((section) => section.title);
const schema = [getFaqSchema(calculator.title, calculator.faqs), getCalculatorSchema(calculator, canonical)];
const sameCategorySwitches = calculators
  .filter((item) => item.category === calculator.category && item.slug !== calculator.slug)
  .slice(0, 5);
const quickSwitchPrimary = [
  ...relatedCalculators,
  ...sameCategorySwitches.filter((item) => !relatedCalculators.some((related) => related.slug === item.slug))
].slice(0, 6);
const quickSwitchGroups = Object.entries(categoryLabels).map(([key, label]) => ({
  key,
  label,
  items: calculators.filter((item) => item.category === key && item.slug !== calculator.slug).slice(0, 4)
}));
const sceneByCategory = {
  fitness: {
    heroClass: "calculator-hero calculator-hero-fitness",
    sceneToneClass: "scene-tone-sage",
    overline: "Performance and body metrics",
    summary: "This page covers body measurements, calories, lean mass, and other numbers tied to weight or training goals.",
    markers: ["Body measurements", "Energy needs", "Training support"]
  },
  nutrition: {
    heroClass: "calculator-hero calculator-hero-nutrition",
    sceneToneClass: "scene-tone-sky",
    overline: "Food intake and fuel planning",
    summary: "This page covers calories, macros, hydration, and the food choices that shape day-to-day eating.",
    markers: ["Calories and macros", "Meal planning", "Daily intake"]
  },
  pregnancy: {
    heroClass: "calculator-hero calculator-hero-pregnancy",
    sceneToneClass: "scene-tone-coral",
    overline: "Gentler planning for pregnancy",
    summary: "This page covers cycle timing, due dates, and pregnancy weight gain ranges in one place.",
    markers: ["Cycle timing", "Due dates", "Weight gain ranges"]
  },
  health: {
    heroClass: "calculator-hero calculator-hero-health",
    sceneToneClass: "scene-tone-foam",
    overline: "Everyday wellness signals",
    summary: "This page covers sleep, heart rate, blood pressure, and other health checks people revisit often.",
    markers: ["Sleep patterns", "Heart metrics", "Daily checks"]
  }
} as const;
const scene = sceneByCategory[calculator.category];
---

<BaseLayout title={calculator.seoTitle} description={calculator.description} canonical={canonical} jsonLd={schema}>
  <section class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
    <div class="space-y-8">
      <section transition:name="calculator-hero" class={`section-shell brand-frame calculator-hero-shell overflow-hidden p-8 sm:p-10 ${scene.heroClass}`}>
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_300px] lg:items-start">
          <div class="max-w-3xl">
            <span class="eyebrow">{categoryLabels[calculator.category]}</span>
            <p class="mt-4 text-xs font-semibold uppercase tracking-[0.2em] text-pine/70">{scene.overline}</p>
            <h1 class="heading-display mt-5">{calculator.title}</h1>
            <p class="mt-5 max-w-2xl text-lg leading-8 text-ink/74">{calculator.intro}</p>
            <div class="mt-8 flex flex-wrap gap-3 text-sm font-semibold text-ink/65">
              <span class="wellness-chip !bg-mint !text-pine !shadow-none">Updated {calculator.updatedAt}</span>
              <span class="wellness-chip !bg-sky !text-pine !shadow-none">{sectionTitles.length} article sections</span>
              <span class="wellness-chip !bg-white/80 !text-pine !shadow-none">Calculator, explanation, and FAQ</span>
            </div>
            <div class="calculator-hero-microgrid mt-6 grid gap-4 sm:grid-cols-3">
              <div class="tinted-panel tinted-panel-sage px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-pine/72">What you get</p>
                <p class="mt-2 text-sm leading-7 text-ink/72">A result, a short explanation, and links to related tools.</p>
              </div>
              <div class="tinted-panel tinted-panel-sky px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-pine/72">Best for</p>
                <p class="mt-2 text-sm leading-7 text-ink/72">{supportingLabel}</p>
              </div>
              <div class="tinted-panel tinted-panel-coral px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-pine/72">Tip</p>
                <p class="mt-2 text-sm leading-7 text-ink/72">Use the calculator first, then read below if you want more context.</p>
              </div>
            </div>
          </div>
          <div class={`scene-card calculator-scene-panel scene-stack hidden lg:block ${scene.sceneToneClass}`}>
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-pine/72">Page scene</p>
                <p class="mt-2 text-xl font-bold text-ink">{scene.overline}</p>
              </div>
              <ToolIcon slug={calculator.slug} size="lg" label={calculator.title} />
            </div>
            <p class="mt-5 text-sm leading-7 text-ink/72">{scene.summary}</p>
            <div class="mt-5 space-y-3">
              {scene.markers.map((marker) => (
                <div class="scene-line">
                  <span class="scene-line-dot"></span>
                  <span>{marker}</span>
                </div>
              ))}
            </div>
            <div class="scene-mini-grid mt-5">
              <div class="scene-mini-card">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-pine/68">Best used for</p>
                <p class="mt-2 text-sm font-bold leading-6 text-ink">{supportingLabel}</p>
              </div>
              <div class="scene-mini-card">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-pine/68">How to use it</p>
                <p class="mt-2 text-sm font-bold leading-6 text-ink">Calculate first, then compare the result with the sections below</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <CalculatorForm
        calculator={calculator}
        quickSwitchPrimary={quickSwitchPrimary}
        quickSwitchGroups={quickSwitchGroups}
        currentCategoryLabel={categoryLabels[calculator.category]}
      />

      {calculator.sections.map((section) => (
        <section class="section-shell brand-frame p-6 sm:p-8" id={section.title.toLowerCase().replaceAll(" ", "-")}>
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Guide</span>
              <h2 class="section-title mt-4">{section.title}</h2>
            </div>
            <div class={`guide-scene-pill ${scene.sceneToneClass}`}>
              <span>{scene.overline}</span>
            </div>
          </div>
          <div class="mt-5 space-y-4 text-base leading-8 text-ink/75">
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets && (
              <ul class="grid gap-3 sm:grid-cols-2">
                {section.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
          </div>
        </section>
      ))}

      <section class="section-shell brand-frame p-6 sm:p-8" id="faq">
        <span class="eyebrow">FAQ</span>
        <h2 class="section-title mt-4">Common questions</h2>
        <p class="mt-4 text-ink/72">Answers to common follow-up questions about {calculator.title.toLowerCase()}.</p>
        <div class="mt-6">
          <FAQ items={calculator.faqs} />
        </div>
      </section>

      {relatedArticles.length > 0 && (
        <section class="space-y-5" id="related-articles">
          <div>
            <span class="eyebrow">Related Articles</span>
            <h2 class="section-title mt-4">Read more on this topic</h2>
            <p class="mt-3 max-w-2xl text-sm leading-7 text-ink/72">
              These articles cover the same topic as {calculator.title.toLowerCase()} if you want a little more background or a closer look at the result.
            </p>
          </div>
          <div class="grid gap-5 md:grid-cols-2">
            {relatedArticles.map((post) => <ArticleCard post={post} />)}
          </div>
        </section>
      )}

      <section class="space-y-5" id="related-calculators">
        <div>
          <span class="eyebrow">Related Calculators</span>
          <h2 class="section-title mt-4">Try a related calculator</h2>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-ink/72">One result often leads to another question. These calculators help you check the next piece of the picture.</p>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          {relatedCalculators.map((item) => <CalculatorCard calculator={item} />)}
        </div>
      </section>
    </div>

    <aside class="grid gap-4 sm:grid-cols-2 lg:sticky lg:top-6 lg:block lg:space-y-6 lg:self-start">
      <div class="section-shell brand-frame p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-pine">On this page</p>
        <p class="mt-3 text-sm leading-6 text-ink/66">Start with the calculator, then scroll for the explanation, FAQ, and related links.</p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-ink/70">
          <li><a href="#calculator" class="hover:text-sage">Calculator</a></li>
          <li><a href="#faq" class="hover:text-sage">FAQ</a></li>
          {relatedArticles.length > 0 && <li><a href="#related-articles" class="hover:text-sage">Related Articles</a></li>}
          <li><a href="#related-calculators" class="hover:text-sage">Related Calculators</a></li>
          {calculator.sections.map((section) => (
            <li>
              <a href={`#${section.title.toLowerCase().replaceAll(" ", "-")}`} class="hover:text-sage">{section.title}</a>
            </li>
          ))}
        </ul>
      </div>
      <div class="tinted-panel tinted-panel-sage px-5 py-5">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-pine/75">How to use this page</p>
        <ol class="mt-3 space-y-3 text-sm leading-7 text-ink/72">
          <li>1. Enter your details in the calculator.</li>
          <li>2. Review the result card and supporting details.</li>
          <li>3. Read the sections below before deciding what to do with the result.</li>
        </ol>
      </div>
      <div class={`scene-card px-5 py-5 ${scene.sceneToneClass}`}>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-pine/75">Why this page works</p>
        <p class="mt-3 text-sm leading-7 text-ink/72">
          It keeps the calculator, explanation, and related links together so you can understand the topic without jumping around.
        </p>
      </div>
    </aside>
  </section>
</BaseLayout>
