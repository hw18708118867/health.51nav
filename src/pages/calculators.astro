---
import BaseLayout from "../layouts/BaseLayout.astro";
import CalculatorCard from "../components/CalculatorCard.astro";
import { calculators, categoryLabels } from "../data/calculators";

const grouped = Object.entries(categoryLabels).map(([key, label]) => ({
  key,
  label,
  items: calculators.filter((calculator) => calculator.category === key)
}));

const categorySummaries = {
  fitness: "Body metrics, metabolism, lean mass, and weight or training tools.",
  nutrition: "Calories, meals, macros, carbs, fats, fiber, and hydration tools.",
  pregnancy: "Ovulation timing, due dates, and pregnancy weight gain tools.",
  health: "Sleep, blood pressure, heart rate, and everyday health tools."
} as const;
---

<BaseLayout
  title="All Calculators - HealthCalcHub"
  description="Browse every calculator on HealthCalcHub by category, with quick access to fitness, nutrition, pregnancy, and daily health tools."
>
  <section class="section-shell brand-frame soft-grid overflow-hidden p-8 sm:p-10">
    <div class="grid gap-8 lg:grid-cols-[1.04fr_0.96fr] lg:items-center">
      <div>
        <div class="flex flex-wrap gap-2">
          <span class="eyebrow">All Calculators</span>
          <span class="wellness-chip">Browse by topic</span>
        </div>
        <h1 class="heading-display mt-5">Find the right calculator without hunting through the homepage.</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/74">
          This page groups the tools the same way most people think about them: body goals, food choices, pregnancy questions, and everyday health checks.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <span class="trust-pill"><span class="info-dot"></span>{calculators.length} calculators</span>
          <span class="trust-pill"><span class="info-dot"></span>Metric and imperial support</span>
          <span class="trust-pill"><span class="info-dot"></span>FAQ and related reading included</span>
        </div>
      </div>
      <div class="topic-pill-grid">
        {grouped.map((group) => (
          <a href={`#${group.key}`} class="topic-pill-card block hover:-translate-y-1 transition duration-300">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-pine">{group.label}</p>
            <p class="mt-3 text-sm leading-7 text-ink/72">
              {categorySummaries[group.key as keyof typeof categorySummaries]}
            </p>
            <p class="mt-4 text-sm font-bold text-pine">{group.items.length} calculators</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {grouped.map((group) => (
    <section class="mt-10" id={group.key}>
      <div class="section-hero-split mb-6">
        <div>
          <span class="eyebrow">{group.label}</span>
          <h2 class="mt-4 font-serif text-4xl text-ink">{group.label} calculators</h2>
        </div>
        <div class="section-intro-card max-w-2xl">
          <p class="text-sm leading-7 text-ink/70">
            {categorySummaries[group.key as keyof typeof categorySummaries]}
          </p>
        </div>
      </div>
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {group.items.map((calculator) => <CalculatorCard calculator={calculator} />)}
      </div>
    </section>
  ))}
</BaseLayout>
